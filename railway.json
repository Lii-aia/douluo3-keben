{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "languages": {
        "python": {
          "version": "3.12"
        }
      }
    }
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "python scripts/heartbeat_cloud.py",
    "cron": {
      "TZ": "Asia/Shanghai",
      "jobs": [
        {
          "command": "python scripts/heartbeat_cloud.py",
          "schedule": "*/15 * * * *",
          "disabled": false
        }
      ]
    }
  }
}
